@model Chapter
@{
    ViewData["Title"] = "Không có nội dung";
    var manga = ViewBag.Manga as Manga;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h4 class="mb-0 text-center">
                        <i class="fas fa-exclamation-triangle text-warning me-2"></i>
                        Không tìm thấy nội dung
                    </h4>
                </div>
                <div class="card-body text-center p-5">
                    <img src="/images/empty-content.svg" alt="No content" class="img-fluid mb-4" style="max-height: 200px;">
                    <h5>Chapter này không có nội dung hoặc đã bị xóa!</h5>
                    <p class="text-muted mb-4">
                        Chúng tôi không thể tải nội dung của Chapter @Model.ChapterNumber của truyện @manga.Title.
                        Vui lòng thử lại sau hoặc chọn chapter khác để đọc.
                    </p>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="/chapter/list/@manga.MangaId" class="btn btn-primary">
                            <i class="fas fa-list me-2"></i> Xem danh sách chapter
                        </a>
                        <a href="/manga/@manga.MangaId" class="btn btn-outline-primary">
                            <i class="fas fa-book me-2"></i> Về trang truyện
                        </a>
                    </div>
                </div>
                <div class="card-footer bg-white text-center">
                    <p class="mb-0 small text-muted">
                        <i class="fas fa-clock me-1"></i> @DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>