@model Mangareading.Models.User
@{
    ViewData["Title"] = "Chi tiết người dùng";
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Dashboard">Trang Quản Trị</a></li>
            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="UserManagement">Quản Lý Người Dùng</a></li>
            <li class="breadcrumb-item active">@Model.Username</li>
        </ol>
    </nav>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Message"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-md-8 mb-4">
            <div class="card">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="fas fa-user-circle me-2"></i>Thông tin người dùng</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">ID:</div>
                        <div class="col-md-8">@Model.UserId</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">Tên người dùng:</div>
                        <div class="col-md-8">@Model.Username</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">Email:</div>
                        <div class="col-md-8">@Model.Email</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">Ngày tạo:</div>
                        <div class="col-md-8">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">Trạng thái:</div>
                        <div class="col-md-8">
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Bị vô hiệu hóa</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="fas fa-cogs me-2"></i>Quản lý tài khoản</h5>
                </div>
                <div class="card-body">
                    <form asp-controller="Admin" asp-action="ToggleUserStatus" asp-route-userId="@Model.UserId" method="post">
                        @if (Model.IsActive)
                        {
                            <button type="submit" class="btn btn-danger w-100 mb-2">
                                <i class="fas fa-ban me-2"></i>Vô hiệu hóa tài khoản
                            </button>
                            <small class="text-muted">Người dùng sẽ không thể đăng nhập khi tài khoản bị vô hiệu hóa.</small>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-success w-100 mb-2">
                                <i class="fas fa-check-circle me-2"></i>Kích hoạt tài khoản
                            </button>
                            <small class="text-muted">Người dùng sẽ có thể đăng nhập trở lại sau khi tài khoản được kích hoạt.</small>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>
</div> 