<!DOCTYPE html>
<html lang="vi" data-theme="@(Context.Session.GetString("UserTheme") ?? "light")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Manga Reader</title>

    <!-- Inline script to prevent theme transition animation on page load -->
    <script>
        // Get theme from localStorage or use the server-side theme
        const savedTheme = localStorage.getItem('theme');
        const serverTheme = document.documentElement.getAttribute('data-theme');

        // Apply theme immediately without transition
        if (savedTheme) {
            document.documentElement.setAttribute('data-theme', savedTheme);
        }

        // Add class to prevent any transitions during page load
        document.documentElement.classList.add('no-transition');

        // Remove the no-transition class after the page has loaded
        window.addEventListener('load', function() {
            setTimeout(function() {
                document.documentElement.classList.remove('no-transition');
            }, 100);
        });
    </script>

    <!-- Critical CSS for theme - load before anything else -->
    <link rel="stylesheet" href="~/css/themes/theme-preload.css" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Theme system -->
    <link rel="stylesheet" href="~/css/themes/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/themes/theme-overrides.css" asp-append-version="true" />

    <!-- Component styles -->
    <link rel="stylesheet" href="~/css/components/buttons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/toaster.css" asp-append-version="true" />

    <!-- Layout styles -->
    <link rel="stylesheet" href="~/css/layouts/reading-layout.css" asp-append-version="true" />

    <!-- Legacy styles (to be refactored) -->
    <link rel="stylesheet" href="~/css/reading.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="reading-mode">
    <main role="main">
        @RenderBody()
    </main>

    <div id="readingSettings" class="reading-settings">
        <h5 class="mb-3">Cài đặt hiển thị</h5>
        <div class="settings-group">
            <label for="readingMode">Chế độ đọc:</label>
            <select id="readingMode" class="form-select">
                <option value="vertical">Đọc cuộn dọc</option>
                <option value="horizontal">Đọc sang ngang</option>
                <option value="webtoon">Chế độ Webtoon</option>
            </select>
        </div>
        <div class="settings-group">
            <label for="pageFit">Kích thước ảnh:</label>
            <select id="pageFit" class="form-select">
                <option value="width">Vừa màn hình</option>
                <option value="height">Vừa chiều cao</option>
                <option value="original">Kích thước gốc</option>
            </select>
        </div>
        <div class="settings-group">
            <label for="bgColor">Màu nền:</label>
            <select id="bgColor" class="form-select">
                <option value="dark">Tối</option>
                @* <option value="black">Đen</option> *@ @* Removed 2025-04-22 *@
                @* <option value="gray">Xám</option> *@ @* Removed 2025-04-22 *@
                <option value="light">Sáng</option>
            </select>
        </div>
        <button id="closeSettings" class="btn btn-reading w-100 mt-2">Áp dụng</button>
    </div>

    <div id="hotkeyInfo" class="hotkey-info">
        <h6 class="mb-2">Phím tắt:</h6>
        <p class="mb-1"><kbd>←</kbd> Chapter trước</p>
        <p class="mb-1"><kbd>→</kbd> Chapter sau</p>
        <p class="mb-1"><kbd>S</kbd> Cài đặt hiển thị</p>
        <p class="mb-1"><kbd>H</kbd> Hiện/ẩn bảng điều khiển</p>
        <p class="mb-0"><kbd>?</kbd> Hiện/ẩn phím tắt</p>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Main script loader -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/theme-switcher.js" asp-append-version="true"></script>
    <script src="~/js/manga-tracking.js" asp-append-version="true"></script>

    <!-- Reading scripts -->
    <script src="~/js/manga-reader.js" asp-append-version="true"></script> @* Contains merged reading functionality *@

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>