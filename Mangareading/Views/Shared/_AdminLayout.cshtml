<!DOCTYPE html>
<html lang="vi" data-theme="@(Context.Session.GetString("UserTheme") ?? "light")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>

    <!-- Inline script to prevent theme transition animation on page load -->
    <script>
        // Get theme from localStorage or use the server-side theme
        const savedTheme = localStorage.getItem('theme');
        const serverTheme = document.documentElement.getAttribute('data-theme');

        // Apply theme immediately without transition
        if (savedTheme) {
            document.documentElement.setAttribute('data-theme', savedTheme);
        }

        // Add class to prevent any transitions during page load
        document.documentElement.classList.add('no-transition');

        // Remove the no-transition class after the page has loaded
        window.addEventListener('load', function() {
            setTimeout(function() {
                document.documentElement.classList.remove('no-transition');
            }, 100);
        });
    </script>

    <!-- Critical CSS for theme - load before anything else -->
    <link rel="stylesheet" href="~/css/themes/theme-preload.css" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/chart.js@3.7.1/dist/chart.min.css">

    <!-- Theme system -->
    <link rel="stylesheet" href="~/css/themes/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/themes/theme-overrides.css" asp-append-version="true" />

    <!-- Component styles -->
    <link rel="stylesheet" href="~/css/components/buttons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/cards.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/toaster.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/admin-dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/admin-dashboard-dark.css" asp-append-version="true" />

    <!-- Layout styles -->
    <link rel="stylesheet" href="~/css/layouts/admin-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layouts/admin-layout-custom.css" asp-append-version="true" />

    <!-- Legacy styles (to be refactored) -->
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="admin-panel">
    <div class="admin-container">
        <!-- Sidebar Navigation -->
        <nav id="sidebar" class="sidebar">
            <div class="sidebar-header">
                <!-- Sidebar toggle button at top of sidebar -->
                <div class="d-flex justify-content-center align-items-center w-100">
                    <button id="sidebarToggle" class="btn sidebar-toggle">
                        <i class="fas fa-bars"></i>
                    </button>
                </div>
            </div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"
                       href="/admin/dashboard">
                        <i class="fas fa-tachometer-alt me-2"></i> <span class="nav-text">Dashboard</span>
                    </a>
                    <div class="nav-tooltip">Dashboard</div>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "UserManagement" ? "active" : "")"
                       href="/admin/users">
                        <i class="fas fa-users me-2"></i> <span class="nav-text">Quản lý người dùng</span>
                    </a>
                    <div class="nav-tooltip">Quản lý người dùng</div>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "MangaManagement" ? "active" : "")"
                       href="/admin/manga">
                        <i class="fas fa-book me-2"></i> <span class="nav-text">Quản lý truyện</span>
                    </a>
                    <div class="nav-tooltip">Quản lý truyện</div>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Statistics" ? "active" : "")"
                       href="/admin/statistics">
                        <i class="fas fa-chart-bar me-2"></i> <span class="nav-text">Thống kê & Báo cáo</span>
                    </a>
                    <div class="nav-tooltip">Thống kê & Báo cáo</div>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "SyncServices" ? "active" : "")"
                       href="/admin/sync-services">
                        <i class="fas fa-sync-alt me-2"></i> <span class="nav-text">Đồng bộ truyện</span>
                    </a>
                    <div class="nav-tooltip">Đồng bộ truyện</div>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Settings" ? "active" : "")"
                       href="/admin/settings">
                        <i class="fas fa-cog me-2"></i> <span class="nav-text">Cài đặt hệ thống</span>
                    </a>
                    <div class="nav-tooltip">Cài đặt hệ thống</div>
                </li>
                <!-- Move theme toggle to sidebar menu -->
                <li class="nav-item">
                    <button id="themeToggleBtn" class="nav-link btn">
                        <i class="fas fa-sun me-2"></i> <span class="nav-text">Chuyển giao diện</span>
                    </button>
                    <div class="nav-tooltip">Chuyển giao diện</div>
                </li>
            </ul>
            <div class="sidebar-footer mt-auto">
                <a href="/" class="btn btn-home">
                    <i class="fas fa-arrow-left me-2"></i> <span class="nav-text">Về trang chủ</span>
                </a>
            </div>
        </nav>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Main Content Area -->
            <div class="content-wrapper">
                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["Message"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.7.1/dist/chart.min.js"></script>

    <!-- Main script loader -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/theme-switcher.js" asp-append-version="true"></script>

    <!-- Legacy scripts (to be refactored) -->
    <script src="~/js/admin.js" asp-append-version="true"></script>
    <script src="~/js/admin-filters.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>