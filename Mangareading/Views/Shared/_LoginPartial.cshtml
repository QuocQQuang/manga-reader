@using Microsoft.AspNetCore.Http

<div class="nav-item dropdown user-info">
    <a class="nav-link dropdown-toggle user-dropdown-toggle @(User.Identity?.IsAuthenticated == true ? "" : "logged-out-icon")" href="#" id="userMenuDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <img src="@(string.IsNullOrEmpty(Context.Session.GetString("AvatarUrl")) ? "/images/default-avatar.png" : Context.Session.GetString("AvatarUrl"))" alt="Avatar" class="user-avatar-sm me-1" />
            <span class="d-none d-lg-inline">@Context.Session.GetString("Username")</span>
        }
        else
        {
            <i class="fas fa-user-circle user-icon-placeholder"></i> 
            <span class="d-none d-lg-inline">Tài khoản</span>
        }
    </a>
    <ul class="dropdown-menu dropdown-menu-end user-dropdown-menu" aria-labelledby="userMenuDropdown">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <li><h6 class="dropdown-header d-lg-none">Chào, @Context.Session.GetString("Username")</h6></li>
            <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="fas fa-user-edit me-2"></i>Hồ sơ</a></li>
            <li><a class="dropdown-item" asp-controller="User" asp-action="Favorites"><i class="fas fa-heart me-2"></i>Truyện yêu thích</a></li>
            <li><a class="dropdown-item" asp-controller="User" asp-action="ReadingHistory"><i class="fas fa-history me-2"></i>Lịch sử đọc</a></li>
            @if (User.IsInRole("Admin"))
            {
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" asp-controller="Admin" asp-action="Dashboard"><i class="fas fa-shield-alt me-2"></i> Quản Trị</a></li>
            }
            <li><hr class="dropdown-divider"></li>
            <li>
                 <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" class="d-inline">
                     <button type="submit" class="dropdown-item text-danger"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</button>
                 </form>
            </li>
        }
        else
        {
            <li><a class="dropdown-item" asp-controller="Account" asp-action="Login"><i class="fas fa-sign-in-alt me-2"></i>Đăng nhập</a></li>
            <li><a class="dropdown-item" asp-controller="Account" asp-action="Register"><i class="fas fa-user-plus me-2"></i>Đăng ký</a></li>
        }
    </ul>
</div>