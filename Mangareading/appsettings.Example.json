{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=MangaReaderDB;User Id=YourUser;Password=YourPassword;MultipleActiveResultSets=true;TrustServerCertificate=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "System": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "None",
      "System.Data.SqlClient": "Warning",
      "Microsoft.Data": "Warning"
    },
    "File": {
      "Enabled": true
    }
  },
  "AWS.Logging": {
    "Region": "us-east-1",
    "LogGroup": "MangaReading.Logs",
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "None",
      "System.Data.SqlClient": "Warning",
      "Microsoft.Data": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      },
      "Https": {
        "Url": "https://0.0.0.0:5001",
        "Certificate": {
          "Development": {
            "Path": "cert-aspnetcore.pfx",
            "Password": "temppassword"
          }
        }
      }
    }
  },
  "AllowedHosts": "*",
  "ExternalServices": {
    "Imgur": {
      "ClientId": "YOUR_CLIENT_ID_HERE",
      "ClientSecret": "YOUR_CLIENT_SECRET_HERE",
      "RefreshToken": "YOUR_REFRESH_TOKEN_HERE"
    }
